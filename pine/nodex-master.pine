//@version=6
// ═══════════════════════════════════════════════════════════════════
// NODEX MASTER · V1 (Pine v6)
// ═══════════════════════════════════════════════════════════════════
//
// À QUOI ÇA SERT :
// L'indicateur ULTIME qui combine les 6 autres en UN seul score de
// qualité 0-6. Quand le score atteint 5 ou 6, il affiche un label
// "BUY A" ou "BUY A+" parce que la qualité du setup le justifie.
// En-dessous, juste un point discret (pas de spam visuel).
//
// LES 6 CONDITIONS VÉRIFIÉES (1 point chacune) :
//   1. HTF HAUSSIER       (EMA 50 H4 > EMA 200 H4)
//   2. SWEEP sur N-1       (mèche au-dessus PDH + clôture en-dessous)
//   3. FVG haussier actif  (low > high[2] dans les 10 dernières bougies)
//   4. BOUGIE 2 confirme   (bougie courante close > open)
//   5. VOLUME SPIKE        (volume > 2× moyenne 20)
//   6. PROCHE LIQUIDITÉ    (prix proche de PDH/PDL/PWH/PWL)
//
// SCORE & AFFICHAGE :
//   - 6/6  = BUY A+   (label vert lumineux, le setup parfait)
//   - 5/6  = BUY A    (label vert)
//   - 4/6  = point bleu discret (setup B, à toi de juger)
//   - <4   = rien (skip)
//
// PANNEAU OPTIONNEL : score live en haut à droite
//
// © 2026 Nodex Trading · V5.2 · Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex Master", shorttitle="NDX-MASTER", overlay=true, max_labels_count=200)

// ─── INPUTS ────────────────────────────────────────────────────────
htfTF        = input.timeframe("240", "Timeframe HTF",        group="Configuration")
fastLen      = input.int(50,   "EMA rapide HTF",              minval=10, maxval=200, group="Configuration")
slowLen      = input.int(200,  "EMA lente HTF",               minval=50, maxval=500, group="Configuration")
minWickPct   = input.float(40.0,"Mèche min sweep (%)",        minval=10, maxval=90, step=5, group="Configuration")
fvgMinSize   = input.float(0.3, "Taille min FVG (%)",         minval=0.05, maxval=5.0, step=0.05, group="Configuration")
fvgLookback  = input.int(10,   "Lookback FVG (bougies)",      minval=3, maxval=50, group="Configuration")
volMult      = input.float(2.0, "Volume spike (x moyenne)",   minval=1.2, maxval=10, step=0.1, group="Configuration")
liqProxPct   = input.float(0.6, "Proximité liquidité (%)",    minval=0.1, maxval=3.0, step=0.1, group="Configuration",
     tooltip="Distance max au PDH/PDL/PWH/PWL en % du prix pour valider la 6e condition.")

showAplusLabel = input.bool(true, "Label 'BUY A+' (score 6/6)", group="Affichage")
showALabel     = input.bool(true, "Label 'BUY A' (score 5/6)",  group="Affichage")
showBdot       = input.bool(true, "Point bleu (score 4/6)",     group="Affichage")
showPanel      = input.bool(true, "Panneau score en coin",      group="Affichage")
panelPos       = input.string("top_right", "Position panneau",
     options=["top_right","top_left","bottom_right","bottom_left"], group="Affichage")

aPlusColor   = input.color(color.new(#4ade80, 0), "Couleur A+", group="Couleurs")
aColor       = input.color(color.new(#4ade80, 30),"Couleur A",  group="Couleurs")
bColor       = input.color(color.new(#6fa8ff, 0), "Couleur B",  group="Couleurs")

// ─── 1. HTF BIAS ───────────────────────────────────────────────────
emaFastHTF = request.security(syminfo.tickerid, htfTF, ta.ema(close, fastLen), lookahead=barmerge.lookahead_off)
emaSlowHTF = request.security(syminfo.tickerid, htfTF, ta.ema(close, slowLen), lookahead=barmerge.lookahead_off)
cond1_htfBullish = emaFastHTF > emaSlowHTF

// ─── 2. SWEEP PDH SUR LA BOUGIE PRÉCÉDENTE ─────────────────────────
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
wickPrev   = high[1] - math.max(open[1], close[1])
rangePrev  = high[1] - low[1]
wickPctPrev = rangePrev > 0 ? (wickPrev / rangePrev) * 100 : 0.0
cond2_sweep = high[1] > pdh and close[1] < pdh and wickPctPrev >= minWickPct

// ─── 3. FVG HAUSSIER ACTIF DANS LES N DERNIÈRES BOUGIES ────────────
hasActiveFVG = false
for i = 2 to fvgLookback
    fvgT = low[i-2]
    fvgB = high[i]
    if low[i-2] > high[i] and ((fvgT - fvgB) / close) * 100 >= fvgMinSize
        // Vérifie qu'il n'a pas été mitigé entre temps
        mitigated = false
        for j = 0 to i - 3
            if low[j] <= fvgT
                mitigated := true
                break
        if not mitigated
            hasActiveFVG := true
            break
cond3_fvgActive = hasActiveFVG

// ─── 4. BOUGIE 2 DE CONFIRMATION ───────────────────────────────────
cond4_confirm = close > open

// ─── 5. VOLUME SPIKE ───────────────────────────────────────────────
volAvg = ta.sma(volume, 20)
cond5_volSpike = volAvg > 0 and volume / volAvg >= volMult

// ─── 6. PROCHE D'UNE ZONE DE LIQUIDITÉ ─────────────────────────────
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_off)
pwh = request.security(syminfo.tickerid, "W", high[1], lookahead=barmerge.lookahead_off)
pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead=barmerge.lookahead_off)

distPct(level) =>
    level > 0 ? math.abs((close - level) / close) * 100 : 999.0

cond6_nearLiq = distPct(pdh) <= liqProxPct or distPct(pdl) <= liqProxPct or distPct(pwh) <= liqProxPct or distPct(pwl) <= liqProxPct

// ─── SCORE TOTAL ───────────────────────────────────────────────────
score = (cond1_htfBullish ? 1 : 0) + (cond2_sweep ? 1 : 0) + (cond3_fvgActive ? 1 : 0) + (cond4_confirm ? 1 : 0) + (cond5_volSpike ? 1 : 0) + (cond6_nearLiq ? 1 : 0)

isAplus = score == 6
isA     = score == 5
isB     = score == 4

// ─── AFFICHAGE LABELS ──────────────────────────────────────────────
if isAplus and showAplusLabel
    label.new(bar_index, low, "BUY A+", style=label.style_label_up, color=aPlusColor, textcolor=color.white, size=size.normal)

if isA and showALabel
    label.new(bar_index, low, "BUY A", style=label.style_label_up, color=aColor, textcolor=color.white, size=size.small)

plotshape(isB and showBdot, title="Setup B (point discret)", style=shape.circle, location=location.belowbar, color=bColor, size=size.tiny)

// ─── PANNEAU LIVE EN COIN ──────────────────────────────────────────
strBool(b) => b ? "✓" : "✗"
colBool(b) => b ? color.new(#4ade80, 0) : color.new(#888888, 50)

scoreText = isAplus ? "A+" : isA ? "A" : isB ? "B" : "—"
scoreCol  = isAplus ? aPlusColor : isA ? aColor : isB ? bColor : color.new(#888888, 30)

var table panel = na
if showPanel and barstate.islast
    if not na(panel)
        table.delete(panel)
    pos = panelPos == "top_right" ? position.top_right :
          panelPos == "top_left"  ? position.top_left  :
          panelPos == "bottom_right" ? position.bottom_right : position.bottom_left

    panel := table.new(pos, 2, 8, bgcolor=color.new(#000000, 30), border_width=1, border_color=color.new(#ffffff, 80))
    table.cell(panel, 0, 0, "NODEX MASTER", bgcolor=color.new(#6fa8ff, 60), text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 0, scoreText + " " + str.tostring(score) + "/6", bgcolor=scoreCol, text_color=color.white, text_size=size.small)
    table.cell(panel, 0, 1, "HTF Haussier", text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 1, strBool(cond1_htfBullish), text_color=colBool(cond1_htfBullish), text_size=size.tiny)
    table.cell(panel, 0, 2, "Sweep PDH N-1",  text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 2, strBool(cond2_sweep), text_color=colBool(cond2_sweep), text_size=size.tiny)
    table.cell(panel, 0, 3, "FVG actif", text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 3, strBool(cond3_fvgActive), text_color=colBool(cond3_fvgActive), text_size=size.tiny)
    table.cell(panel, 0, 4, "Bougie 2 OK", text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 4, strBool(cond4_confirm), text_color=colBool(cond4_confirm), text_size=size.tiny)
    table.cell(panel, 0, 5, "Volume spike", text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 5, strBool(cond5_volSpike), text_color=colBool(cond5_volSpike), text_size=size.tiny)
    table.cell(panel, 0, 6, "Proche liquidité", text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 1, 6, strBool(cond6_nearLiq), text_color=colBool(cond6_nearLiq), text_size=size.tiny)

// ─── ALERTES ───────────────────────────────────────────────────────
alertcondition(isAplus, title="Nodex BUY A+ (6/6)", message="🔥 SETUP A+ sur {{ticker}} {{interval}} — toutes les conditions Nodex V5.2 réunies.")
alertcondition(isA,     title="Nodex BUY A (5/6)",  message="✓ SETUP A sur {{ticker}} {{interval}} — 5/6 conditions Nodex.")
alertcondition(isB,     title="Nodex Setup B (4/6)", message="Setup B sur {{ticker}} {{interval}} — 4/6, à toi de juger.")
