//@version=6
// ═══════════════════════════════════════════════════════════════════
// NODEX FVG AUTO · V2 (Pine v6)
// ═══════════════════════════════════════════════════════════════════
//
// À QUOI ÇA SERT :
// Détecte les FVG haussiers (Fair Value Gap) et trace un RECTANGLE
// VERT SIMPLE avec "FVG" écrit dedans. Discret, pas oppressant.
// Disparaît automatiquement quand le prix mitige (touche) le FVG.
//
// CE QUE TU VOIS :
//   - Rectangle vert pâle là où il y a un FVG haussier
//   - Texte "FVG" centré
//   - Disparition auto à la mitigation
//
// CONDITIONS (mêmes que V1) :
//   - low de la bougie courante > high de la bougie n-2
//   - Taille minimum 0.3% du prix (filtre les micro-gaps)
//
// © 2026 Nodex Trading · V5.2 · Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex FVG Auto", shorttitle="NDX-FVG", overlay=true, max_boxes_count=100, max_labels_count=100)

// ─── INPUTS ────────────────────────────────────────────────────────
minSizePct  = input.float(0.3,  "Taille minimum FVG (%)", minval=0.05, maxval=5.0, step=0.05, group="Détection",
     tooltip="Filtre les micro-gaps. 0.3% = équilibré.")
maxAgeBars  = input.int(80,    "Effacer après N bougies", minval=20, maxval=500, group="Affichage")
boxColor    = input.color(color.new(#4ade80, 88), "Couleur rectangle", group="Affichage")
borderColor = input.color(color.new(#4ade80, 65), "Couleur bordure",   group="Affichage")
textColor   = input.color(color.new(#4ade80, 30), "Couleur texte FVG", group="Affichage")
showText    = input.bool(true, "Afficher le texte 'FVG'",              group="Affichage")

// ─── ARRAYS POUR SUIVRE LES FVG ACTIFS ─────────────────────────────
var array<box>   activeBoxes  = array.new<box>()
var array<label> activeLabels = array.new<label>()
var array<float> topPrices    = array.new<float>()

// ─── DÉTECTION FVG HAUSSIER ────────────────────────────────────────
// FVG haussier = low courant > high n-2 (trou entre les deux bougies)
fvgTop = low
fvgBot = high[2]
isFVG  = low > high[2]
sizePct = isFVG ? ((fvgTop - fvgBot) / close) * 100 : 0.0

if isFVG and sizePct >= minSizePct
    // Crée rectangle vert pâle
    newBox = box.new(bar_index - 2, fvgTop, bar_index + 25, fvgBot,
         border_color=borderColor, bgcolor=boxColor, border_width=1)
    array.push(activeBoxes, newBox)
    array.push(topPrices, fvgTop)

    // Label "FVG" centré au milieu du rectangle
    midPrice = (fvgTop + fvgBot) / 2
    newLabel = label.new(bar_index + 11, midPrice, showText ? "FVG" : "",
         style=label.style_none, textcolor=textColor, size=size.small)
    array.push(activeLabels, newLabel)

// ─── MITIGATION + EFFACEMENT AUTO ──────────────────────────────────
if array.size(activeBoxes) > 0
    for i = array.size(activeBoxes) - 1 to 0
        b = array.get(activeBoxes, i)
        l = array.get(activeLabels, i)
        topPx = array.get(topPrices, i)

        // Mitigation = la mèche basse touche le haut du FVG
        isMitigated = low <= topPx
        // Trop ancien
        isTooOld    = bar_index - box.get_left(b) > maxAgeBars

        if isMitigated or isTooOld
            box.delete(b)
            label.delete(l)
            array.remove(activeBoxes, i)
            array.remove(activeLabels, i)
            array.remove(topPrices, i)
        else
            // Étend rectangle + repositionne label
            box.set_right(b, bar_index + 5)
            label.set_x(l, bar_index - 8)

// ─── ALERTE ────────────────────────────────────────────────────────
alertcondition(isFVG and sizePct >= minSizePct, title="Nodex FVG Haussier",
     message="FVG haussier sur {{ticker}} {{interval}} — surveille la mitigation.")
