//@version=6
// ═══════════════════════════════════════════════════════════════════
// NODEX HTF BIAS · V2 (Pine v6)
// ═══════════════════════════════════════════════════════════════════
//
// À QUOI ÇA SERT :
// Te dit en UN SEUL COUP D'ŒIL si le marché est HAUSSIER ou BAISSIER
// en H4 (Higher Time Frame). Si HAUSSIER → tu peux chercher des longs.
// Si BAISSIER → tu skippes le trade.
//
// COMMENT ÇA MARCHE (logique simple) :
//   - Compare 2 moyennes mobiles (EMA 50 et EMA 200) sur le H4
//   - Si EMA 50 > EMA 200 → tendance HAUSSIÈRE
//   - Si EMA 50 < EMA 200 → tendance BAISSIÈRE
//
// CE QUE TU VOIS :
//   - Un petit panneau en haut à droite : "HTF: HAUSSIER" en vert
//     ou "HTF: BAISSIER" en rouge
//   - Optionnel : les 2 EMA H4 affichées sur ton chart
//
// © 2026 Nodex Trading · V5.2 · Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex HTF Bias", shorttitle="NDX-HTF", overlay=true)

// ─── INPUTS ────────────────────────────────────────────────────────
htf         = input.timeframe("240", "Timeframe HTF", group="Configuration",
     tooltip="240 = H4 (recommandé). Tu peux mettre 60 (H1) ou D (Daily).")
fastLen     = input.int(50,  "EMA rapide",  minval=10, maxval=200, group="EMA")
slowLen     = input.int(200, "EMA lente",   minval=50, maxval=500, group="EMA")
showEMAs    = input.bool(true,  "Afficher les EMA HTF sur le chart", group="Affichage")
showPanel   = input.bool(true,  "Afficher le panneau HTF",            group="Affichage")
panelPos    = input.string("top_right", "Position panneau",
     options=["top_right","top_left","bottom_right","bottom_left"], group="Affichage")
greenC      = input.color(color.new(#4ade80, 0), "Couleur HAUSSIER", group="Couleurs")
redC        = input.color(color.new(#ef4444, 0), "Couleur BAISSIER", group="Couleurs")

// ─── RÉCUPÈRE LES EMA EN HTF ───────────────────────────────────────
emaFast = request.security(syminfo.tickerid, htf, ta.ema(close, fastLen), lookahead=barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htf, ta.ema(close, slowLen), lookahead=barmerge.lookahead_off)

// ─── CALCUL DU BIAIS ───────────────────────────────────────────────
isBullish = emaFast > emaSlow
biasText  = isBullish ? "HAUSSIER" : "BAISSIER"
biasColor = isBullish ? greenC : redC

// ─── AFFICHAGE EMA HTF (optionnel) ─────────────────────────────────
plot(showEMAs ? emaFast : na, title="EMA Fast HTF", color=color.new(#6fa8ff, 30), linewidth=2)
plot(showEMAs ? emaSlow : na, title="EMA Slow HTF", color=color.new(#c8d8ff, 50), linewidth=2)

// ─── PANNEAU SIMPLE EN COIN ────────────────────────────────────────
var table panel = na
if showPanel and barstate.islast
    if not na(panel)
        table.delete(panel)
    pos = panelPos == "top_right" ? position.top_right :
          panelPos == "top_left"  ? position.top_left  :
          panelPos == "bottom_right" ? position.bottom_right : position.bottom_left

    panel := table.new(pos, 1, 2, bgcolor=color.new(#000000, 30), border_width=1, border_color=color.new(#ffffff, 80))
    table.cell(panel, 0, 0, "HTF " + htf, bgcolor=color.new(#000000, 50), text_color=color.new(#ffffff, 30), text_size=size.tiny)
    table.cell(panel, 0, 1, biasText, bgcolor=biasColor, text_color=color.white, text_size=size.normal)

// ─── ALERTES ───────────────────────────────────────────────────────
alertcondition(isBullish and not isBullish[1], title="Nodex HTF passe HAUSSIER", message="HTF passe HAUSSIER sur {{ticker}}.")
alertcondition(not isBullish and isBullish[1], title="Nodex HTF passe BAISSIER", message="HTF passe BAISSIER sur {{ticker}}.")
