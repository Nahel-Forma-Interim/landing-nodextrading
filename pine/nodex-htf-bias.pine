//@version=5
// ═══════════════════════════════════════════════════════════════════
// NODEX HTF BIAS — V1.0
// ═══════════════════════════════════════════════════════════════════
// Détermine automatiquement le biais HTF (H4 + H1) pour valider ou
// invalider un setup M15. Affiche un panneau de contrôle avec :
//   - Structure H4 (HH/HL ou LH/LL)
//   - Structure H1 (HH/HL ou LH/LL)
//   - EMA 50/200 H4 (alignement)
//   - Verdict final : LONG OK / SHORT OK / NO TRADE
//
// Règle Nodex V5.2 : si HTF n'est pas haussier, on ne prend PAS le trade.
//
// © 2026 Nodex Trading — Strategy V5.2 — Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex HTF Bias", shorttitle="NDX-HTF", overlay=true)

// ─── INPUTS ────────────────────────────────────────────────────────
grpStruct = "Structure"
swingLength = input.int(5, "Swing length", minval=2, maxval=20, group=grpStruct,
     tooltip="Nombre de bougies pour détecter un swing high/low.")

grpEMA = "EMA"
emaFast = input.int(50, "EMA rapide", minval=10, maxval=200, group=grpEMA)
emaSlow = input.int(200, "EMA lente", minval=50, maxval=500, group=grpEMA)
showEMAh4 = input.bool(true, "Afficher EMA H4 sur le chart", group=grpEMA)

grpVisu = "Affichage"
showPanel = input.bool(true, "Afficher panneau bias", group=grpVisu)
panelPos = input.string("top_left", "Position panneau", options=["top_right","top_left","bottom_right","bottom_left"], group=grpVisu)
greenC = input.color(color.new(#4ade80, 0), "Couleur OK", group=grpVisu)
redC = input.color(color.new(#ef4444, 0), "Couleur KO", group=grpVisu)
neutralC = input.color(color.new(#f59e0b, 0), "Couleur neutre", group=grpVisu)

// ─── DÉTECTION STRUCTURE ─────────────────────────────────────────
detectStructure(htf) =>
    h = request.security(syminfo.tickerid, htf, high, lookahead=barmerge.lookahead_off)
    l = request.security(syminfo.tickerid, htf, low, lookahead=barmerge.lookahead_off)
    pivH = ta.pivothigh(h, swingLength, swingLength)
    pivL = ta.pivotlow(l, swingLength, swingLength)
    var float lastH = na
    var float prevH = na
    var float lastL = na
    var float prevL = na
    if not na(pivH)
        prevH := lastH
        lastH := pivH
    if not na(pivL)
        prevL := lastL
        lastL := pivL
    bullish = not na(prevH) and not na(prevL) and lastH > prevH and lastL > prevL
    bearish = not na(prevH) and not na(prevL) and lastH < prevH and lastL < prevL
    bullish ? 1 : bearish ? -1 : 0

biasH4 = detectStructure("240")
biasH1 = detectStructure("60")

// ─── EMA HTF ───────────────────────────────────────────────────────
ema50_h4 = request.security(syminfo.tickerid, "240", ta.ema(close, emaFast), lookahead=barmerge.lookahead_off)
ema200_h4 = request.security(syminfo.tickerid, "240", ta.ema(close, emaSlow), lookahead=barmerge.lookahead_off)
emaAligned = ema50_h4 > ema200_h4 ? 1 : ema50_h4 < ema200_h4 ? -1 : 0

if showEMAh4
    plot(ema50_h4, title="EMA 50 H4", color=color.new(#6fa8ff, 30), linewidth=2)
    plot(ema200_h4, title="EMA 200 H4", color=color.new(#c8d8ff, 50), linewidth=2)

// ─── VERDICT GLOBAL ─────────────────────────────────────────────
score = 0
score := biasH4 == 1 ? score + 1 : biasH4 == -1 ? score - 1 : score
score := biasH1 == 1 ? score + 1 : biasH1 == -1 ? score - 1 : score
score := emaAligned == 1 ? score + 1 : emaAligned == -1 ? score - 1 : score

verdict = score >= 2 ? "LONG OK" : score <= -2 ? "SHORT OK" : "NO TRADE"
verdictColor = score >= 2 ? greenC : score <= -2 ? redC : neutralC

// ─── PANNEAU ───────────────────────────────────────────────────────
strBias(b) =>
    b == 1 ? "Bullish" : b == -1 ? "Bearish" : "Neutre"
colBias(b) =>
    b == 1 ? greenC : b == -1 ? redC : neutralC

var table panel = na
if showPanel and barstate.islast
    if not na(panel)
        table.delete(panel)
    pos = panelPos == "top_right" ? position.top_right : panelPos == "top_left" ? position.top_left : panelPos == "bottom_right" ? position.bottom_right : position.bottom_left
    panel := table.new(pos, 2, 6, bgcolor=color.new(#000000, 20), border_width=1, border_color=color.new(#ffffff, 80))
    table.cell(panel, 0, 0, "NODEX HTF BIAS", bgcolor=color.new(#6fa8ff, 60), text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 0, syminfo.ticker, bgcolor=color.new(#6fa8ff, 60), text_color=color.white, text_size=size.small)
    table.cell(panel, 0, 1, "Structure H4", text_color=color.new(#ffffff, 40), text_size=size.tiny)
    table.cell(panel, 1, 1, strBias(biasH4), text_color=colBias(biasH4), text_size=size.tiny)
    table.cell(panel, 0, 2, "Structure H1", text_color=color.new(#ffffff, 40), text_size=size.tiny)
    table.cell(panel, 1, 2, strBias(biasH1), text_color=colBias(biasH1), text_size=size.tiny)
    table.cell(panel, 0, 3, "EMA 50/200 H4", text_color=color.new(#ffffff, 40), text_size=size.tiny)
    table.cell(panel, 1, 3, emaAligned == 1 ? "Aligné UP" : emaAligned == -1 ? "Aligné DOWN" : "Neutre", text_color=colBias(emaAligned), text_size=size.tiny)
    table.cell(panel, 0, 4, "Score", text_color=color.new(#ffffff, 40), text_size=size.tiny)
    table.cell(panel, 1, 4, str.tostring(score) + " / 3", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 5, "Verdict", bgcolor=color.new(#000000, 50), text_color=color.white, text_size=size.small)
    table.cell(panel, 1, 5, verdict, bgcolor=verdictColor, text_color=color.white, text_size=size.small)

// ─── ALERTES ───────────────────────────────────────────────────────
alertcondition(score >= 2 and score[1] < 2, title="Nodex HTF Long OK", message="Bias HTF passe LONG OK sur {{ticker}}.")
alertcondition(score <= -2 and score[1] > -2, title="Nodex HTF Short OK", message="Bias HTF passe SHORT OK sur {{ticker}}.")
