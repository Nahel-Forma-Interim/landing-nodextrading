//@version=6
// ═══════════════════════════════════════════════════════════════════
// NODEX SWEEP DETECTOR · V2 (Pine v6)
// ═══════════════════════════════════════════════════════════════════
//
// À QUOI ÇA SERT :
// Trace une LIGNE BLEUE au niveau du PDH (Previous Day High = plus
// haut de la veille). Quand la mèche d'une bougie passe AU-DESSUS
// puis que la bougie CLÔTURE EN-DESSOUS, c'est un SWEEP : le marché
// est venu prendre la liquidité des shorts puis a rejeté. C'est ton
// signal d'entrée Nodex.
//
// CE QUE TU VOIS :
//   - Une ligne bleue horizontale = PDH du jour
//   - Un label "SWEEP" rouge au-dessus de la mèche quand détecté
//   - Une alerte sonore TradingView possible
//
// PARAMÈTRES SIMPLES (pas besoin de toucher) :
//   - Mèche minimum : 40% du range de la bougie (filtre les faux)
//
// © 2026 Nodex Trading · V5.2 · Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex Sweep Detector", shorttitle="NDX-SWEEP", overlay=true, max_labels_count=200, max_lines_count=50)

// ─── INPUTS ────────────────────────────────────────────────────────
showLine    = input.bool(true,  "Afficher la ligne PDH",       group="Affichage")
showLabel   = input.bool(true,  "Afficher le label SWEEP",     group="Affichage")
lineColor   = input.color(color.new(#6fa8ff, 0), "Couleur PDH", group="Affichage")
sweepColor  = input.color(color.new(#ef4444, 0), "Couleur SWEEP", group="Affichage")
minWickPct  = input.float(40.0, "Mèche minimum (% du range)",  minval=10, maxval=90, step=5, group="Sensibilité",
     tooltip="Plus le % est haut, plus le sweep doit être agressif. 40% = équilibré.")

// ─── RÉCUPÈRE LE PDH (Previous Day High) ───────────────────────────
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)

// ─── DÉTECTION DU SWEEP ────────────────────────────────────────────
// Sweep = la bougie a dépassé le PDH avec sa mèche, puis est revenue clôturer dessous
wickAbove   = high - math.max(open, close)         // taille mèche supérieure
barRange    = high - low
wickRatio   = barRange > 0 ? (wickAbove / barRange) * 100 : 0.0
wickIsBig   = wickRatio >= minWickPct

isSweep = high > pdh and close < pdh and wickIsBig

// ─── AFFICHAGE LIGNE PDH (mise à jour à chaque bougie) ─────────────
var line pdhLine = na
if showLine
    line.delete(pdhLine)
    pdhLine := line.new(bar_index - 50, pdh, bar_index + 5, pdh, color=lineColor, width=1, style=line.style_solid)

// ─── AFFICHAGE LABEL SWEEP ─────────────────────────────────────────
if isSweep and showLabel
    label.new(bar_index, high, "SWEEP", style=label.style_label_down, color=sweepColor, textcolor=color.white, size=size.small)

// ─── ALERTE ────────────────────────────────────────────────────────
alertcondition(isSweep, title="Nodex Sweep PDH", message="SWEEP détecté sur {{ticker}} {{interval}} — vérifie le FVG après.")

// ─── TRIANGLE DISCRET POUR DEBUG ───────────────────────────────────
plotshape(isSweep, title="Sweep marker", style=shape.triangledown, location=location.abovebar, color=sweepColor, size=size.tiny)
