//@version=5
// ═══════════════════════════════════════════════════════════════════
// NODEX VOLUME FILTER — V1.0
// ═══════════════════════════════════════════════════════════════════
// Filtre de qualité par le volume institutionnel. Affiche un tableau
// permanent qui valide ou invalide la session pour le setup Nodex.
//
// Critères :
//   - Volume 24h > seuil minimum
//   - Volume bougie courante > moyenne 20 (pour confirmer un sweep)
//   - Volume cumulé session NYAM (M15) en croissance
//   - Anomalie volume détectée (> 3x moyenne = institutionnel)
//
// © 2026 Nodex Trading — Strategy V5.2 — Licence personnelle
// ═══════════════════════════════════════════════════════════════════

indicator("Nodex Volume Filter", shorttitle="NDX-VOL", overlay=true)

// ─── INPUTS ────────────────────────────────────────────────────────
grpThr = "Seuils"
minVol24h = input.float(50.0, "Volume 24h min. ($M)", minval=1, maxval=10000, step=10, group=grpThr,
     tooltip="Volume 24h minimum en millions de dollars (recommandé : 50M$ pour les alts).")
volSpikeMult = input.float(3.0, "Anomalie volume (x)", minval=1.5, maxval=10, step=0.5, group=grpThr,
     tooltip="Multiplicateur par rapport à la moyenne pour signaler une anomalie.")
volTrendMult = input.float(1.2, "Volume confirmation (x)", minval=1.0, maxval=3.0, step=0.1, group=grpThr,
     tooltip="Multiplicateur pour valider qu'une bougie a du volume.")

grpSession = "Session"
useSessionFilter = input.bool(true, "Filtrer NYAM (13h-16h UTC)", group=grpSession)
sessionStart = input.session("1330-1600", "Session NYAM (UTC)", group=grpSession)

grpVisu = "Affichage"
showTable = input.bool(true, "Afficher le tableau", group=grpVisu)
tablePos = input.string("top_right", "Position tableau", options=["top_right","top_left","bottom_right","bottom_left"], group=grpVisu)
showSpikeLabel = input.bool(true, "Label anomalie volume", group=grpVisu)
spikeColor = input.color(color.new(#f59e0b, 0), "Couleur anomalie", group=grpVisu)

// ─── CALCULS ───────────────────────────────────────────────────────
volAvg20 = ta.sma(volume, 20)
vol24hUSD = request.security(syminfo.tickerid, "D", volume * close, lookahead=barmerge.lookahead_off) / 1000000
vol24hOK = vol24hUSD >= minVol24h

volCurrent = volume
volRatio = volAvg20 > 0 ? volCurrent / volAvg20 : 0
isSpike = volRatio >= volSpikeMult
isConfirm = volRatio >= volTrendMult

// Session
inSession = not useSessionFilter or not na(time(timeframe.period, sessionStart))

// Score qualité 0-3
score = 0
score := vol24hOK ? score + 1 : score
score := isConfirm ? score + 1 : score
score := inSession ? score + 1 : score

scoreText = score == 3 ? "EXCELLENT" : score == 2 ? "OK" : score == 1 ? "MOYEN" : "REJETÉ"
scoreColor = score == 3 ? color.new(#4ade80, 0) : score == 2 ? color.new(#6fa8ff, 0) : score == 1 ? color.new(#f59e0b, 0) : color.new(#ef4444, 0)

// ─── TABLEAU PERMANENT ─────────────────────────────────────────────
var table tbl = na
if showTable
    if barstate.islast
        if not na(tbl)
            table.delete(tbl)
        pos = tablePos == "top_right" ? position.top_right : tablePos == "top_left" ? position.top_left : tablePos == "bottom_right" ? position.bottom_right : position.bottom_left
        tbl := table.new(pos, 2, 6, bgcolor=color.new(#000000, 20), border_width=1, border_color=color.new(#ffffff, 80))
        table.cell(tbl, 0, 0, "NODEX VOL", bgcolor=color.new(#6fa8ff, 60), text_color=color.white, text_size=size.small)
        table.cell(tbl, 1, 0, syminfo.ticker, bgcolor=color.new(#6fa8ff, 60), text_color=color.white, text_size=size.small)
        table.cell(tbl, 0, 1, "Vol 24h", text_color=color.new(#ffffff, 40), text_size=size.tiny)
        table.cell(tbl, 1, 1, str.tostring(vol24hUSD, "#.#") + "M$", text_color=vol24hOK ? color.new(#4ade80, 0) : color.new(#ef4444, 0), text_size=size.tiny)
        table.cell(tbl, 0, 2, "Vol bar", text_color=color.new(#ffffff, 40), text_size=size.tiny)
        table.cell(tbl, 1, 2, str.tostring(volRatio, "#.##") + "x", text_color=isConfirm ? color.new(#4ade80, 0) : color.new(#ffffff, 50), text_size=size.tiny)
        table.cell(tbl, 0, 3, "Session", text_color=color.new(#ffffff, 40), text_size=size.tiny)
        table.cell(tbl, 1, 3, inSession ? "ACTIVE" : "OFF", text_color=inSession ? color.new(#4ade80, 0) : color.new(#888888, 0), text_size=size.tiny)
        table.cell(tbl, 0, 4, "Anomalie", text_color=color.new(#ffffff, 40), text_size=size.tiny)
        table.cell(tbl, 1, 4, isSpike ? "OUI " + str.tostring(volRatio, "#.#") + "x" : "—", text_color=isSpike ? color.new(#f59e0b, 0) : color.new(#888888, 0), text_size=size.tiny)
        table.cell(tbl, 0, 5, "Score", bgcolor=color.new(#000000, 50), text_color=color.white, text_size=size.small)
        table.cell(tbl, 1, 5, scoreText, bgcolor=scoreColor, text_color=color.white, text_size=size.small)

// ─── LABELS ANOMALIE ───────────────────────────────────────────────
if isSpike and showSpikeLabel
    label.new(bar_index, low, "VOL " + str.tostring(volRatio, "#.#") + "x", style=label.style_label_up, color=spikeColor, textcolor=color.white, size=size.tiny)

// ─── ALERTES ───────────────────────────────────────────────────────
alertcondition(isSpike, title="Nodex Volume Spike", message="Anomalie volume {{ticker}} {{interval}} — possible mouvement institutionnel.")
alertcondition(score == 3, title="Nodex Score 3/3", message="Setup volume optimal sur {{ticker}} {{interval}}.")
